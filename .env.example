# Frontend (exposed to the browser via Vite)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Scraper-only (never exposed to the browser)
SUPABASE_SERVICE_KEY=your-service-role-key
APIFY_TOKEN=your-apify-token
GROQ_API_KEY=your-groq-api-key

# Optional scraper tuning
# SCRAPE_WINDOW_DAYS=1   # how far back to fetch posts (default 1)
# RETENTION_DAYS=7       # how long to keep rows before purging (default 7)
# GROQ_MODEL=llama-3.3-70b-versatile
